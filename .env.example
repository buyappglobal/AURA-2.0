# Aura Business V2.0 - Configuración de Entorno

# URL del motor central (Google Cloud Run / AI Studio)
# Ejemplo: https://aura-cloud-engine-xxxx.run.app
GOOGLE_CLOUD_URL=

# Clave de seguridad para la comunicación Cloudflare -> Google
# Cámbiala por una cadena aleatoria larga
AURA_SECRET_KEY=

# Firebase Admin (Opcional si se despliega en Google Cloud con service accounts)
# FIREBASE_CONFIG=
